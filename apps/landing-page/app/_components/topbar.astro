---
import {
  DEFAULT_LOCALE,
  LANDING_LOCALES,
  getCommonCopy,
  isLandingLocale,
} from '../i18n';

const REPO = 'https://github.com/nexu-io/open-design';
const REPO_RELEASES = `${REPO}/releases`;
const ext = {
  target: '_blank',
  rel: 'noreferrer noopener',
} as const;
const NBSP = '\u00A0';
const { github = { versionLabel: 'v0.3.0' }, locale: rawLocale = DEFAULT_LOCALE } =
  Astro.props;
const locale = isLandingLocale(rawLocale) ? rawLocale : DEFAULT_LOCALE;
const copy = getCommonCopy(locale).topbar;
---

<div class='topbar' data-od-id='topbar'>
  <div class='container topbar-inner'>
    <span>
      <b>OD / 2026</b>{NBSP}·{NBSP}Vol. 01 / Issue Nº 26
    </span>
    <span class='mid'>
      <span>
        {copy.filedUnder} <b class='coral'>{copy.category}</b>
      </span>
      <span>{copy.madeOnEarth}</span>
    </span>
    <span class='right'>
      <a class='topbar-link' href={REPO_RELEASES} {...ext}>
        <span class='pulse'></span>
        {copy.live} · <span data-github-version>{github.versionLabel}</span>
      </a>
      <label class='locale-switch'>
        <span class='sr-only'>{copy.languageSwitcherLabel}</span>
        <select
          class='locale-select'
          data-locale-select
          aria-label={copy.languageSwitcherLabel}
        >
          {LANDING_LOCALES.map((entry) => (
            <option value={entry.code} selected={entry.code === locale}>
              {entry.label}
            </option>
          ))}
        </select>
      </label>
    </span>
  </div>
</div>
